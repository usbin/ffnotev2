<Window x:Class="ffnotev2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ffnotev2.Controls"
        Title="ffnote v2"
        Width="1200" Height="780"
        MinWidth="700" MinHeight="500"
        Background="#1E1E1E"
        Closing="Window_Closing">
    <Window.InputBindings>
        <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding PasteCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="140" MaxWidth="320"/>
            <ColumnDefinition Width="3"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 사이드바 -->
        <DockPanel Grid.Column="0" Background="#1A1A1A">
            <StackPanel DockPanel.Dock="Top" Margin="10,10,10,6">
                <TextBlock Text="ffnote v2" Foreground="#555" FontSize="10" Margin="0,0,0,8"/>
                <Button Content="+ 새 노트북"
                        Command="{Binding AddNotebookCommand}"
                        Padding="0,7"
                        HorizontalAlignment="Stretch"
                        Background="#3D5A80" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#3D5A80"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#4A6FA0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListBox ItemsSource="{Binding Notebooks}"
                         SelectedItem="{Binding CurrentNotebook}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2A3D52"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#252525"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="10,5" LastChildFill="True">
                                <Button DockPanel.Dock="Right" Content="…"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#555" Cursor="Hand" Padding="4,0"
                                        Click="NotebookMenu_Click" Tag="{Binding}"
                                        FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" FontSize="13"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </DockPanel>

        <!-- 구분선 -->
        <GridSplitter Grid.Column="1" Width="3" Background="#111"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <!-- 캔버스 영역 -->
        <Grid Grid.Column="2">
            <ItemsControl x:Name="NoteItemsControl"
                          ItemsSource="{Binding CurrentNotebook.Notes}"
                          Background="#232323"
                          Focusable="True">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas x:Name="NoteCanvas" Background="Transparent"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:DraggableNoteControl/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 빈 캔버스 안내 문구 -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        IsHitTestVisible="False">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentNotebook.Notes.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="Ctrl+V" Foreground="#333" FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="텍스트, 이미지, 링크를 붙여넣으세요"
                           Foreground="#333" FontSize="13" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 노트북 미선택 안내 -->
            <TextBlock Text="← 노트북을 선택하거나 새로 만드세요"
                       Foreground="#333" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasCurrentNotebook}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
    </Grid>
</Window>
