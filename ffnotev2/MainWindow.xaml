<Window x:Class="ffnotev2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:ffnotev2.Controls"
        xmlns:m="clr-namespace:ffnotev2.Models"
        xmlns:conv="clr-namespace:ffnotev2.Converters"
        Title="ffnote v2" Height="700" Width="1100"
        Background="#FF1E1E1E"
        Foreground="#FFEEEEEE"
        Focusable="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 사이드바 -->
        <Border Grid.Column="0" Background="#FF252525" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="노트북" FontWeight="Bold" Margin="0,0,0,8"/>
                <ListBox Grid.Row="1" x:Name="NotebookList"
                         ItemsSource="{Binding Notebooks}"
                         SelectedItem="{Binding CurrentNotebook, Mode=TwoWay}"
                         Background="Transparent" Foreground="#FFEEEEEE" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type m:NoteBook}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="⋯" Width="22" Height="22"
                                        Background="Transparent" BorderThickness="0" Foreground="#FFCCCCCC"
                                        Click="NotebookMenu_Click" Tag="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Grid.Row="2" Content="+ 노트북 추가" Margin="0,8,0,0" Padding="6"
                        Command="{Binding CreateNotebookCommand}"/>
            </Grid>
        </Border>

        <!-- 캔버스 영역 -->
        <Grid Grid.Column="1" Background="#FF1E1E1E"
              MouseRightButtonUp="Canvas_MouseRightButtonUp">
            <ItemsControl ItemsSource="{Binding CurrentNotebook.Notes}"
                          Visibility="{Binding HasCurrentNotebook, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="Transparent" ClipToBounds="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style>
                        <Setter Property="Canvas.Left" Value="{Binding X, Mode=TwoWay}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y, Mode=TwoWay}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ctl:DraggableNoteControl/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="노트북을 추가하거나 선택하세요"
                       Foreground="#FF888888" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding HasCurrentNotebook, Converter={StaticResource InvBoolToVis}}"/>
        </Grid>
    </Grid>
</Window>
