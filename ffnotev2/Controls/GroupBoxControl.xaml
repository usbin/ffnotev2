<UserControl x:Class="ffnotev2.Controls.GroupBoxControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="{Binding Width}" Height="{Binding Height}"
             Background="Transparent"
             Cursor="SizeAll">
    <!-- 점선 사각형. Stroke만, Fill 없음 → 내부 클릭은 통과되어 노트가 작동.
         Stroke 부분(테두리)에서만 hit-test되어 그룹 드래그/선택 가능 -->
    <Rectangle StrokeThickness="2" StrokeDashArray="4 3"
               Fill="{x:Null}"
               MouseLeftButtonDown="GroupBox_MouseLeftButtonDown"
               MouseMove="GroupBox_MouseMove"
               MouseLeftButtonUp="GroupBox_MouseLeftButtonUp"
               MouseRightButtonUp="GroupBox_MouseRightButtonUp">
        <Rectangle.Style>
            <Style TargetType="Rectangle">
                <Setter Property="Stroke" Value="#FF888888"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Stroke" Value="#FF5599FF"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Rectangle.Style>
    </Rectangle>
</UserControl>
