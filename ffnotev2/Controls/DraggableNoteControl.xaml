<UserControl x:Class="ffnotev2.Controls.DraggableNoteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ffnotev2.Converters"
             Width="{Binding Width}" Height="{Binding Height}"
             Loaded="UserControl_Loaded"
             PreviewMouseLeftButtonDown="UserControl_PreviewMouseLeftButtonDown">
    <UserControl.Resources>
        <conv:NoteTypeToVisibilityConverter x:Key="TypeVis"/>
        <conv:PathToImageConverter x:Key="PathToImage"/>
    </UserControl.Resources>
    <Border Background="#FF2C2C2C" CornerRadius="4">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="#FF555555"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="BorderBrush" Value="#FF5599FF"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <!-- 안쪽: 본문 (타이틀바 + 콘텐츠 영역) -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="22"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

            <!-- 타이틀바 (드래그 영역) -->
            <Border Grid.Row="0" Background="#FF3C3C3C" CornerRadius="4,4,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseMove="TitleBar_MouseMove"
                    MouseLeftButtonUp="TitleBar_MouseLeftButtonUp"
                    Cursor="SizeAll">
                <TextBlock Text="{Binding Type}" Foreground="#FFAAAAAA"
                           VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11"/>
            </Border>

            <!-- 콘텐츠 영역. 노트가 선택된 상태(IsSelected=true)면 본문 어디서든 드래그 가능.
                 더블클릭(편집 진입), 편집 중 캐럿 이동, 하이퍼링크 클릭은 그대로 동작 — Body* 핸들러가
                 첫 클릭(미선택→선택 전환)·이중 클릭·편집 중 케이스를 통과시킴 -->
            <Grid Grid.Row="1"
                  MouseLeftButtonDown="BodyDrag_MouseLeftButtonDown"
                  MouseMove="BodyDrag_MouseMove"
                  MouseLeftButtonUp="BodyDrag_MouseLeftButtonUp">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Cursor" Value="SizeAll"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <!-- 텍스트: 표시(TextBlock)와 편집(TextBox)을 스왑해서 IME 컨텍스트 버그 회피 -->
                <Grid Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=Text}">
                    <ScrollViewer x:Name="TextDisplayScroll"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="6"
                                  CanContentScroll="False">
                        <TextBlock x:Name="TextDisplay"
                                   Text="{Binding Content}"
                                   Foreground="#FFEEEEEE"
                                   TextWrapping="Wrap"
                                   MouseLeftButtonDown="TextDisplay_MouseLeftButtonDown"/>
                    </ScrollViewer>
                    <TextBox x:Name="TextEditor"
                             Visibility="Collapsed"
                             Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="#FFEEEEEE"
                             CaretBrush="#FFEEEEEE"
                             BorderThickness="0"
                             Padding="6"
                             InputMethod.IsInputMethodEnabled="True"
                             InputMethod.PreferredImeState="On"
                             LostFocus="TextEditor_LostFocus"
                             PreviewKeyDown="TextEditor_PreviewKeyDown"/>
                </Grid>
                <!-- 이미지: 빠른 스케일링 모드(드래그 리사이즈 시 매 프레임 부하 감소) -->
                <Image Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=Image}"
                       Source="{Binding Content, Converter={StaticResource PathToImage}}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="LowQuality"/>
                <!-- 링크 -->
                <TextBlock Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=Link}"
                           VerticalAlignment="Center" Margin="8" TextWrapping="Wrap">
                    <Hyperlink NavigateUri="{Binding Content}" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="{Binding Content}"/>
                    </Hyperlink>
                </TextBlock>
            </Grid>

        </Grid>

            <!-- 외곽 리사이즈 핸들 (상/하/좌/우, 5px 두께. 투명하지만 hit-testable) -->
            <Thumb Tag="Top" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="5"
                   Cursor="SizeNS"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Tag="Bottom" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="5"
                   Cursor="SizeNS"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Tag="Left" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="5"
                   Cursor="SizeWE"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Tag="Right" HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="5"
                   Cursor="SizeWE"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- 4 코너 리사이즈 핸들 (대각선, 10×10 투명, 외곽 thumb보다 위에 배치 — 코너 영역에서 우선 적용) -->
            <Thumb Tag="TopLeft" Width="10" Height="10"
                   HorizontalAlignment="Left" VerticalAlignment="Top"
                   Cursor="SizeNWSE"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Tag="TopRight" Width="10" Height="10"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   Cursor="SizeNESW"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Tag="BottomLeft" Width="10" Height="10"
                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                   Cursor="SizeNESW"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Tag="BottomRight" Width="10" Height="10"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Cursor="SizeNWSE"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</UserControl>
