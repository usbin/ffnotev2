<UserControl x:Class="ffnotev2.Controls.DraggableNoteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ffnotev2.Converters"
             Width="{Binding Width}" Height="{Binding Height}"
             Loaded="UserControl_Loaded"
             PreviewMouseLeftButtonDown="UserControl_PreviewMouseLeftButtonDown">
    <UserControl.Resources>
        <conv:NoteTypeToVisibilityConverter x:Key="TypeVis"/>
        <conv:PathToImageConverter x:Key="PathToImage"/>
    </UserControl.Resources>
    <Border Background="#FF2C2C2C" CornerRadius="4">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="#FF555555"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="BorderBrush" Value="#FF5599FF"/>
                        <Setter Property="BorderThickness" Value="2"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="22"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 타이틀바 (드래그 영역) -->
            <Border Grid.Row="0" Background="#FF3C3C3C" CornerRadius="4,4,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseMove="TitleBar_MouseMove"
                    MouseLeftButtonUp="TitleBar_MouseLeftButtonUp"
                    Cursor="SizeAll">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Type}" Foreground="#FFAAAAAA"
                               VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11"/>
                    <Button Grid.Column="1" Content="×" Width="22" Height="22"
                            Background="Transparent" BorderThickness="0" Foreground="#FFCCCCCC"
                            Click="Delete_Click"/>
                </Grid>
            </Border>

            <!-- 콘텐츠 영역 -->
            <Grid Grid.Row="1">
                <!-- 텍스트: 표시(TextBlock)와 편집(TextBox)을 스왑해서 IME 컨텍스트 버그 회피 -->
                <Grid Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=Text}">
                    <ScrollViewer x:Name="TextDisplayScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="6">
                        <TextBlock x:Name="TextDisplay"
                                   Text="{Binding Content}"
                                   Foreground="#FFEEEEEE"
                                   TextWrapping="Wrap"
                                   MouseLeftButtonDown="TextDisplay_MouseLeftButtonDown"/>
                    </ScrollViewer>
                    <TextBox x:Name="TextEditor"
                             Visibility="Collapsed"
                             Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="#FFEEEEEE"
                             CaretBrush="#FFEEEEEE"
                             BorderThickness="0"
                             Padding="6"
                             InputMethod.IsInputMethodEnabled="True"
                             InputMethod.PreferredImeState="On"
                             LostFocus="TextEditor_LostFocus"
                             PreviewKeyDown="TextEditor_PreviewKeyDown"/>
                </Grid>
                <!-- 이미지 -->
                <Image Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=Image}"
                       Source="{Binding Content, Converter={StaticResource PathToImage}}"
                       Stretch="Uniform"/>
                <!-- 링크 -->
                <TextBlock Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=Link}"
                           VerticalAlignment="Center" Margin="8" TextWrapping="Wrap">
                    <Hyperlink NavigateUri="{Binding Content}" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="{Binding Content}"/>
                    </Hyperlink>
                </TextBlock>
            </Grid>

        </Grid>

            <!-- 외곽 리사이즈 핸들 (상/하/좌/우, 5px 두께. 투명하지만 hit-testable) -->
            <Thumb Tag="Top" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="5"
                   Cursor="SizeNS"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Tag="Bottom" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="5"
                   Cursor="SizeNS"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Tag="Left" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="5"
                   Cursor="SizeWE"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb Tag="Right" HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="5"
                   Cursor="SizeWE"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb"><Border Background="Transparent"/></ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <!-- 코너 리사이즈 핸들 (우하단, 가시적, 외곽보다 위에 배치 — 14×14 영역에서 우선 적용) -->
            <Thumb Tag="Corner" Width="14" Height="14"
                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Cursor="SizeNWSE"
                   DragStarted="ResizeThumb_DragStarted"
                   DragDelta="ResizeThumb_DragDelta"
                   DragCompleted="ResizeThumb_DragCompleted">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Path Data="M 0,14 L 14,14 L 14,0 Z" Fill="#FF777777"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</UserControl>
