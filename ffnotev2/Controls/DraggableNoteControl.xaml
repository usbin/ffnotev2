<UserControl x:Class="ffnotev2.Controls.DraggableNoteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ffnotev2.Converters"
             Width="{Binding Width}" Height="{Binding Height}"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <conv:NoteTypeToVisibilityConverter x:Key="TypeVis"/>
        <conv:PathToImageConverter x:Key="PathImg"/>
    </UserControl.Resources>

    <Border Background="#2D2D2D" BorderBrush="#484848" BorderThickness="1" CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="22"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 드래그 핸들 (타이틀 바) -->
            <Border Grid.Row="0" Background="#383838" CornerRadius="5,5,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    MouseLeftButtonUp="TitleBar_MouseLeftButtonUp"
                    MouseMove="TitleBar_MouseMove"
                    Cursor="SizeAll">
                <DockPanel Margin="6,0,2,0">
                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding Type}" Foreground="#666"
                               FontSize="9" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="✕"
                            Click="Delete_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#666" FontSize="10" Padding="4,0"
                            Cursor="Hand" VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#CC3333"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </DockPanel>
            </Border>

            <!-- 내용 영역 -->
            <Grid Grid.Row="1" Margin="6,4,6,6">

                <!-- 텍스트 노트 -->
                <TextBox x:Name="TextBox"
                         Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=Text}"
                         Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#E0E0E0" FontSize="12"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True"
                         MouseDoubleClick="TextBox_MouseDoubleClick"
                         LostFocus="TextBox_LostFocus"
                         CaretBrush="#E0E0E0"
                         SelectionBrush="#5B9BD5"/>

                <!-- 이미지 노트 -->
                <Image Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=Image}"
                       Source="{Binding Content, Converter={StaticResource PathImg}}"
                       Stretch="Uniform" StretchDirection="DownOnly"/>

                <!-- 링크 노트 -->
                <TextBlock Visibility="{Binding Type, Converter={StaticResource TypeVis}, ConverterParameter=Link}"
                           TextWrapping="Wrap" VerticalAlignment="Center">
                    <Hyperlink NavigateUri="{Binding Content}"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="#5B9BD5">
                        <Run Text="{Binding Content}"/>
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </Grid>
    </Border>
</UserControl>
