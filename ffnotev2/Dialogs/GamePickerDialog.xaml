<Window x:Class="ffnotev2.Dialogs.GamePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="게임 프로세스 연동"
        Width="440" Height="380"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="현재 실행 중인 프로그램에서 연동할 게임을 선택하세요."
                   Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"/>

        <ListBox x:Name="ProcessList" Grid.Row="1"
                 Background="#2D2D2D" BorderBrush="#444" BorderThickness="1"
                 Foreground="#E0E0E0" FontSize="12"
                 MouseDoubleClick="ProcessList_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,5"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3D5A80"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="새로고침" Click="Refresh_Click" Width="80" Margin="0,0,8,0"
                    Background="#3D3D3D" Foreground="#E0E0E0" BorderThickness="0" Padding="0,6"/>
            <Button Content="취소" Click="Cancel_Click" Width="70" Margin="0,0,8,0"
                    Background="#3D3D3D" Foreground="#E0E0E0" BorderThickness="0" Padding="0,6"/>
            <Button Content="선택" Click="Select_Click" Width="70"
                    Background="#3D5A80" Foreground="White" BorderThickness="0" Padding="0,6"/>
        </StackPanel>
    </Grid>
</Window>
