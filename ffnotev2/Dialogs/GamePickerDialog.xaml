<Window x:Class="ffnotev2.Dialogs.GamePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="게임 프로세스 선택" Height="420" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Margin="0,0,0,8"
                   Text="현재 실행 중인 창이 있는 프로세스 목록입니다. 게임 실행 파일을 선택하세요."
                   TextWrapping="Wrap"/>
        <ListView Grid.Row="1" x:Name="ProcessList"
                  MouseDoubleClick="ProcessList_MouseDoubleClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="프로세스" Width="180"
                                    DisplayMemberBinding="{Binding ProcessName}"/>
                    <GridViewColumn Header="창 제목" Width="240"
                                    DisplayMemberBinding="{Binding WindowTitle}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="새로고침" Width="80" Margin="0,0,8,0" Click="Refresh_Click"/>
            <Button Content="선택" Width="80" Margin="0,0,8,0" Click="Select_Click" IsDefault="True"/>
            <Button Content="취소" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
