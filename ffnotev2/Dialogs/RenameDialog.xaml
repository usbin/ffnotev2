<Window x:Class="ffnotev2.Dialogs.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="이름 변경"
        Width="320" Height="130"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="NameBox" Grid.Row="0"
                 Background="#2D2D2D" Foreground="#E0E0E0"
                 BorderBrush="#555" BorderThickness="1"
                 Padding="6,5" FontSize="13"
                 KeyDown="NameBox_KeyDown"
                 VerticalAlignment="Center"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="취소" Click="Cancel_Click" Width="70" Margin="0,0,8,0"
                    Background="#3D3D3D" Foreground="#E0E0E0" BorderThickness="0" Padding="0,6"/>
            <Button Content="확인" Click="Ok_Click" Width="70"
                    Background="#3D5A80" Foreground="White" BorderThickness="0" Padding="0,6"/>
        </StackPanel>
    </Grid>
</Window>
