<Window x:Class="ffnotev2.Dialogs.HotkeySettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="단축키 설정" Height="280" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,12" TextWrapping="Wrap" Foreground="#FF555555">
            각 항목을 클릭한 뒤 원하는 키 조합을 누르세요. (Ctrl/Alt/Shift/Win + 영문/숫자/펑션 키)
        </TextBlock>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="메인 창 표시" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="ShowMainBox" Padding="6"
                     IsReadOnly="True" Cursor="Hand"
                     Tag="ShowMain"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                     GotFocus="HotkeyBox_GotFocus"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="오버레이 토글" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="ToggleOverlayBox" Padding="6"
                     IsReadOnly="True" Cursor="Hand"
                     Tag="ToggleOverlay"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                     GotFocus="HotkeyBox_GotFocus"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="클릭 패스스루 토글" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="ToggleClickThroughBox" Padding="6"
                     IsReadOnly="True" Cursor="Hand"
                     Tag="ToggleClickThrough"
                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                     GotFocus="HotkeyBox_GotFocus"/>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="기본값" Width="80" Margin="0,0,8,0" Click="Reset_Click"/>
            <Button Content="저장" Width="80" Margin="0,0,8,0" Click="Save_Click" IsDefault="True"/>
            <Button Content="취소" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
