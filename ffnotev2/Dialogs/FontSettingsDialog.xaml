<Window x:Class="ffnotev2.Dialogs.FontSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="폰트 설정" Height="380" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FF1E1E1E" Foreground="#FFEEEEEE">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,12" TextWrapping="Wrap" Foreground="#FFAAAAAA">
            텍스트 노트의 표시·편집에 사용될 폰트를 설정합니다.
        </TextBlock>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="폰트" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1" x:Name="FontCombo" Padding="6"
                      SelectionChanged="OnAnyChanged"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="크기" VerticalAlignment="Center"/>
            <Slider Grid.Column="1" x:Name="SizeSlider"
                    Minimum="9" Maximum="28" SmallChange="1" LargeChange="2"
                    IsSnapToTickEnabled="True" TickFrequency="1"
                    ValueChanged="OnAnyChanged"/>
            <TextBlock Grid.Column="2" x:Name="SizeLabel" Width="32" TextAlignment="Right"
                       VerticalAlignment="Center" Margin="6,0,0,0"/>
        </Grid>

        <Border Grid.Row="3" Background="#FF2C2C2C" CornerRadius="4" Padding="10" Margin="0,8,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="PreviewText" TextWrapping="Wrap" Foreground="#FFEEEEEE">
                    The quick brown fox jumps over the lazy dog.&#x0a;가나다라마바사 0123456789&#x0a;🎮 🚀 🔥 ⭐ 😀 ❤
                </TextBlock>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="기본값" Width="80" Margin="0,0,8,0" Click="Reset_Click"/>
            <Button Content="저장" Width="80" Margin="0,0,8,0" Click="Save_Click" IsDefault="True"/>
            <Button Content="취소" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
