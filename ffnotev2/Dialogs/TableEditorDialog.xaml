<Window x:Class="ffnotev2.Dialogs.TableEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="표 편집" Height="500" Width="780"
        WindowStartupLocation="CenterOwner"
        MinHeight="320" MinWidth="500">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="+ 행" Click="AddRow_Click" Width="60" Margin="0,0,4,0"/>
            <Button Content="− 행" Click="DeleteRow_Click" Width="60" Margin="0,0,12,0"/>
            <Button Content="+ 열" Click="AddCol_Click" Width="60" Margin="0,0,4,0"/>
            <Button Content="− 열" Click="DeleteCol_Click" Width="60"/>
            <TextBlock Text="(컬럼 헤더 클릭=열 선택 후 −열, 더블클릭=이름 변경, 행 선택 후 −행)"
                       Foreground="#FF888888" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="11"
                       ToolTip="컬럼 헤더를 클릭하면 그 열이 선택되어 −열로 삭제됩니다. 더블클릭은 이름 변경, 행 선택 후 −행."/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="확인" Width="80" Margin="0,0,8,0" Click="Confirm_Click" IsDefault="True"/>
            <Button Content="취소" Width="80" IsCancel="True"/>
        </StackPanel>
        <DataGrid x:Name="Grid"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  CanUserReorderColumns="True"
                  HeadersVisibility="Column"
                  SelectionMode="Extended"
                  SelectionUnit="CellOrRowHeader"
                  GridLinesVisibility="All"
                  BorderBrush="#FFCCCCCC"
                  BorderThickness="1"
                  ColumnHeaderHeight="28"
                  RowHeaderWidth="20"
                  AutoGeneratedColumns="Grid_AutoGeneratedColumns"
                  AutoGeneratingColumn="Grid_AutoGeneratingColumn"
                  PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown"
                  PreviewMouseDoubleClick="Grid_PreviewMouseDoubleClick">
        </DataGrid>
    </DockPanel>
</Window>
