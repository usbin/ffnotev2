<Window x:Class="ffnotev2.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ffnote overlay"
        Width="300" Height="90"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Left="20" Top="20">
    <Border Background="#CC1A1A1A" CornerRadius="8"
            BorderBrush="#333" BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Grid Margin="10,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,5">
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding CurrentNotebookName}"
                           Foreground="#888" FontSize="10"
                           VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="✕" Foreground="#555" FontSize="10"
                           VerticalAlignment="Center" Cursor="Hand"
                           MouseLeftButtonDown="CloseOverlay_Click"/>
            </DockPanel>

            <TextBox Grid.Row="1"
                     x:Name="QuickInput"
                     Text="{Binding QuickNoteText, UpdateSourceTrigger=PropertyChanged}"
                     Background="#2A2A2A" Foreground="#E0E0E0"
                     BorderBrush="#444" BorderThickness="1"
                     Padding="6,4" FontSize="12"
                     VerticalAlignment="Stretch"
                     CaretBrush="#E0E0E0"
                     KeyDown="QuickInput_KeyDown">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Resources>
                            <VisualBrush x:Key="Hint" TileMode="None" Opacity="0.4" Stretch="None" AlignmentX="Left">
                                <VisualBrush.Visual>
                                    <TextBlock Text="메모 입력 후 Enter..." Foreground="#888" FontSize="12" Margin="2,0"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Style.Resources>
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background" Value="{StaticResource Hint}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>
    </Border>
</Window>
