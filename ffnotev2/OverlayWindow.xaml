<Window x:Class="ffnotev2.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ffnote overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="420"
        WindowStartupLocation="Manual"
        Left="40" Top="40">
    <Border x:Name="RootBorder"
            Background="#CC1E1E1E" CornerRadius="6" BorderBrush="#FF555555" BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown"
            MouseRightButtonUp="Border_MouseRightButtonUp">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Foreground="#FFAAAAAA" FontSize="11">
                    <Run Text="ffnote · "/>
                    <Run Text="{Binding CurrentNotebookName}"/>
                </TextBlock>
                <TextBlock Grid.Column="1" x:Name="ClickThroughIndicator"
                           Text="🖱 패스스루" Foreground="#FFFFB347" FontSize="11"
                           Visibility="Collapsed"/>
            </Grid>
            <TextBox Grid.Row="1" x:Name="QuickInput"
                     Text="{Binding QuickNoteText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Background="#FF2C2C2C" Foreground="#FFEEEEEE"
                     BorderThickness="0" Padding="6"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="36" MaxHeight="200"
                     VerticalScrollBarVisibility="Auto"
                     KeyDown="QuickInput_KeyDown"
                     TextChanged="QuickInput_TextChanged"/>
        </Grid>
    </Border>
</Window>
